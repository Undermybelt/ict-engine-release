### 2. Rust 完整定义（直接复制进 `src/ict_pda.rs`）

```rust
use serde::{Deserialize, Serialize};

// ====================== 基础 Candle ======================
#[derive(Debug, Clone, Copy, Serialize, Deserialize)]
pub struct Candle {
    pub open: f64,
    pub high: f64,
    pub low: f64,
    pub close: f64,
    pub volume: f64,
    // timestamp 等可自行扩展
}

// ====================== PDA 类型 + 精确检测条件 ======================
#[derive(Debug, Clone, Copy, PartialEq, Serialize, Deserialize)]
pub enum PDArrayType {
    OrderBlock,      // 机构最后反向蜡烛区
    FairValueGap,    // FVG（BISI/SIBI）
    InverseFVG,      // iFVG
    BreakerBlock,
    MitigationBlock,
    RejectionBlock,
    PropulsionBlock,
    LiquidityVoid,
    VolumeImbalance,
}

impl PDArrayType {
    // 示例：检测函数（可直接在 factor-research 里调用）
    pub fn detect(candles: &[Candle], index: usize) -> Option<(Self, f64, f64)> {  // 返回 (类型, 高, 低)
        if index < 2 { return None; }

        let c0 = candles[index - 2];  // 前前根
        let c1 = candles[index - 1];  // 中间根（常为位移根）
        let c2 = candles[index];      // 当前根

        // 1. OrderBlock (OB)：最后反向蜡烛 + 强位移
        if (c1.close < c1.open && c2.close > c1.high) || (c1.close > c1.open && c2.close < c1.low) {
            return Some((PDArrayType::OrderBlock, c1.high, c1.low));
        }

        // 2. FairValueGap (FVG / BISI / SIBI)：3 根 K 线不重叠
        if c2.low > c0.high {  // 看涨 FVG (BISI)
            return Some((PDArrayType::FairValueGap, c0.high, c2.low));
        }
        if c2.high < c0.low {  // 看跌 FVG (SIBI)
            return Some((PDArrayType::FairValueGap, c2.high, c0.low));
        }

        // 3. InverseFVG (iFVG)：反向不平衡（价格回踩后又反向形成 gap）
        if (c2.low > c0.high && c1.close < c1.open) || (c2.high < c0.low && c1.close > c1.open) {
            return Some((PDArrayType::InverseFVG, c0.high, c2.low));
        }

        // 4. BreakerBlock：价格突破旧高/低后，回踩失效的 OB
        // 条件：当前 K 线突破前高/低，且前一根是 OB
        if (c2.high > c0.high || c2.low < c0.low) && candles[index-1].close < candles[index-1].open {
            return Some((PDArrayType::BreakerBlock, c0.high, c0.low));
        }

        // 5. MitigationBlock：失败摆动（未突破前高/低就反转）
        if (c2.high < c0.high && c1.close > c1.open && c2.close < c1.close) || 
           (c2.low > c0.low && c1.close < c1.open && c2.close > c1.close) {
            return Some((PDArrayType::MitigationBlock, c1.high, c1.low));
        }

        // 6. RejectionBlock：强烈拒绝（长影线 + 收盘远离极值）
        let body = (c2.close - c2.open).abs();
        let upper_wick = c2.high - c2.close.max(c2.open);
        let lower_wick = c2.open.min(c2.close) - c2.low;
        if upper_wick > body * 2.0 || lower_wick > body * 2.0 {
            return Some((PDArrayType::RejectionBlock, c2.high, c2.low));
        }

        // 7. PropulsionBlock：推动块（极强位移蜡烛）
        let displacement = (c2.close - c2.open).abs() / ((c2.high - c2.low) + 1e-9);
        if displacement > 0.7 && c2.volume > 2.0 * candles[index-1].volume {
            return Some((PDArrayType::PropulsionBlock, c2.high, c2.low));
        }

        // 8. LiquidityVoid：流动性空洞（前后 K 线间巨大缺口）
        if (c2.low - c0.high) > 0.0030 || (c0.low - c2.high) > 0.0030 {  // 30 点以上缺口（可调）
            return Some((PDArrayType::LiquidityVoid, c0.high, c2.low));
        }

        // 9. VolumeImbalance：成交量极端失衡
        let avg_vol: f64 = candles.iter().map(|c| c.volume).sum::<f64>() / candles.len() as f64;
        if c2.volume > avg_vol * 3.0 {
            return Some((PDArrayType::VolumeImbalance, c2.high, c2.low));
        }

        None
    }
}
```

### 3. Python 版（快速原型 / 测试用）

```python
from dataclasses import dataclass
from typing import Optional, Tuple

@dataclass
class Candle:
    open: float
    high: float
    low: float
    close: float
    volume: float

class PDArrayType(str, Enum):
    ORDER_BLOCK = "OrderBlock"
    FAIR_VALUE_GAP = "FairValueGap"
    INVERSE_FVG = "InverseFVG"
    BREAKER_BLOCK = "BreakerBlock"
    MITIGATION_BLOCK = "MitigationBlock"
    REJECTION_BLOCK = "RejectionBlock"
    PROPULSION_BLOCK = "PropulsionBlock"
    LIQUIDITY_VOID = "LiquidityVoid"
    VOLUME_IMBALANCE = "VolumeImbalance"

def detect_pda(candles: list[Candle], index: int) -> Optional[Tuple[PDArrayType, float, float]]:
    if index < 2:
        return None
    c0, c1, c2 = candles[index-2], candles[index-1], candles[index]

    # OrderBlock
    if (c1.close < c1.open and c2.close > c1.high) or (c1.close > c1.open and c2.close < c1.low):
        return PDArrayType.ORDER_BLOCK, c1.high, c1.low

    # FairValueGap
    if c2.low > c0.high:
        return PDArrayType.FAIR_VALUE_GAP, c0.high, c2.low
    if c2.high < c0.low:
        return PDArrayType.FAIR_VALUE_GAP, c2.high, c0.low

    # InverseFVG（反向不平衡）
    if (c2.low > c0.high and c1.close < c1.open) or (c2.high < c0.low and c1.close > c1.open):
        return PDArrayType.INVERSE_FVG, c0.high, c2.low

    # BreakerBlock（突破后失效）
    if (c2.high > c0.high or c2.low < c0.low):
        return PDArrayType.BREAKER_BLOCK, c0.high, c0.low

    # MitigationBlock（失败摆动）
    if (c2.high < c0.high and c1.close > c1.open and c2.close < c1.close) or \
       (c2.low > c0.low and c1.close < c1.open and c2.close > c1.close):
        return PDArrayType.MITIGATION_BLOCK, c1.high, c1.low

    # RejectionBlock（长影线拒绝）
    body = abs(c2.close - c2.open)
    if (c2.high - max(c2.open, c2.close)) > body * 2 or (min(c2.open, c2.close) - c2.low) > body * 2:
        return PDArrayType.REJECTION_BLOCK, c2.high, c2.low

    # PropulsionBlock（推动块）
    displacement = abs(c2.close - c2.open) / (c2.high - c2.low + 1e-9)
    if displacement > 0.7 and c2.volume > 2 * c1.volume:
        return PDArrayType.PROPULSION_BLOCK, c2.high, c2.low

    # LiquidityVoid（大缺口）
    if abs(c2.low - c0.high) > 0.0030 or abs(c0.low - c2.high) > 0.0030:
        return PDArrayType.LIQUIDITY_VOID, c0.high, c2.low

    # VolumeImbalance（成交量失衡）
    avg_vol = sum(c.volume for c in candles) / len(candles)
    if c2.volume > avg_vol * 3:
        return PDArrayType.VOLUME_IMBALANCE, c2.high, c2.low

    return None
```

